# Copy this file to `.env` for local development. Do NOT commit `.env`.
# On Netlify, set these in Site settings -> Environment variables instead.

# --- Database -------------------------------------------------------------
# Netlify DB (Neon) injects NETLIFY_DATABASE_URL automatically in production.
# For local dev, paste your Neon connection string into one of these:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# NETLIFY_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Admin login ----------------------------------------------------------
# The single account allowed to write diary entries.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-a-long-password"

# --- Session signing ------------------------------------------------------
# Secret used to sign the login cookie. Generate a random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"
