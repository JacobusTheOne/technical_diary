---
import { t } from '../lib/i18n';
import type { Post } from '../lib/posts';

interface Props {
	action: string;
	// When present the form is pre-filled for editing; otherwise it's a new entry.
	post?: Post;
}

const { action, post } = Astro.props;
const strings = t(Astro.locals.lang);

// Format a Date as YYYY-MM-DD using local parts, matching how entries are saved.
function toDateInput(date: Date): string {
	const y = date.getFullYear();
	const m = String(date.getMonth() + 1).padStart(2, '0');
	const d = String(date.getDate()).padStart(2, '0');
	return `${y}-${m}-${d}`;
}

const dateValue = toDateInput(post?.pubDate ?? new Date());
---

<form method="POST" action={action}>
	<label>
		{strings.fieldTitle}
		<input type="text" name="title" value={post?.title ?? ''} required autofocus />
	</label>
	<label>
		{strings.fieldDate}
		<input type="date" name="pubDate" value={dateValue} required />
	</label>
	<label>
		{strings.fieldBody} <span class="hint">{strings.markdownHint}</span>
		<textarea name="body" rows="16" required>{post?.body ?? ''}</textarea>
	</label>
	<button type="submit" class="publish">{post ? strings.save : strings.publish}</button>
</form>
<style>
	form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 1rem;
	}
	label {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-weight: 700;
	}
	.hint {
		font-weight: 400;
		color: rgb(var(--gray));
		font-size: 0.85rem;
	}
	input,
	textarea {
		padding: 0.6rem 0.75rem;
		font-size: 1rem;
		font-family: inherit;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
	}
	textarea {
		resize: vertical;
		line-height: 1.5;
	}
	.publish {
		align-self: flex-start;
		padding: 0.7rem 1.4rem;
		font-size: 1rem;
		font-weight: 700;
		color: white;
		background: var(--accent);
		border: none;
		border-radius: 8px;
		cursor: pointer;
	}
	.publish:hover {
		background: var(--accent-dark);
	}
</style>
