---
import { strings } from '../lib/strings';

interface Props {
	action: string;
	// JSON to prefill the textarea: the template for new, or the todo for edit.
	json: string;
	isEdit?: boolean;
}

const { action, json, isEdit = false } = Astro.props;
---

<form method="POST" action={action} class="todo-form">
	{isEdit && <input type="hidden" name="_action" value="update" />}
	<label>
		<span class="hint">{strings.jsonHint}</span>
		<textarea name="json" rows="22" spellcheck="false" required>{json}</textarea>
	</label>
	<p class="json-error" hidden></p>
	<button type="submit" class="publish">{isEdit ? strings.save : strings.publish}</button>
</form>
<script is:inline define:vars={{ invalidJsonMessage: strings.errInvalidJson }}>
	const form = document.querySelector('.todo-form');
	const textarea = form?.querySelector('textarea[name="json"]');
	const errorBox = form?.querySelector('.json-error');
	form?.addEventListener('submit', (event) => {
		try {
			JSON.parse(textarea.value);
			errorBox.hidden = true;
		} catch {
			// Block submit so the pasted content isn't lost to a redirect.
			event.preventDefault();
			errorBox.textContent = invalidJsonMessage;
			errorBox.hidden = false;
			textarea.focus();
		}
	});
</script>
<style>
	.todo-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 1rem;
	}
	label {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.hint {
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
	textarea {
		padding: 0.75rem;
		font-size: 0.95rem;
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		line-height: 1.5;
		tab-size: 2;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		resize: vertical;
	}
	.json-error {
		margin: 0;
		color: #b00020;
		font-weight: 700;
	}
	.publish {
		align-self: flex-start;
		padding: 0.7rem 1.4rem;
		font-size: 1rem;
		font-weight: 700;
		color: white;
		background: var(--accent);
		border: none;
		border-radius: 8px;
		cursor: pointer;
	}
	.publish:hover {
		background: var(--accent-dark);
	}
</style>
