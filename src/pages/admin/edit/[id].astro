---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostForm from '../../../components/PostForm.astro';
import { findPostById } from '../../../lib/posts';
import { strings } from '../../../lib/strings';

// Middleware already guarantees a logged-in user here.
const id = Number(Astro.params.id);
const post = Number.isInteger(id) ? await findPostById(id) : undefined;
if (!post) return Astro.redirect('/blog', 302);

const error = Astro.url.searchParams.get('error');
const errorMessage =
	error === 'missing' ? strings.errMissing : error === 'date' ? strings.errDate : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={strings.editHeading} description="Edit a diary entry." />
	</head>
	<body>
		<Header />
		<main>
			<div class="bar">
				<h1>{strings.editHeading}</h1>
				<form method="POST" action="/api/logout" class="logout">
					<button type="submit">{strings.logout}</button>
				</form>
			</div>
			{errorMessage && <p class="error">{errorMessage}</p>}
			<PostForm action={`/api/posts/${post.id}`} post={post} />
		</main>
		<Footer />
		<style>
			.bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}
			.logout button {
				background: none;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 0.4rem 0.8rem;
				color: rgb(var(--gray));
				cursor: pointer;
				font-size: 0.9rem;
			}
			.error {
				color: #b00020;
				font-weight: 700;
			}
		</style>
	</body>
</html>
