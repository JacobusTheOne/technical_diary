---
import BaseHead from '../../../../components/BaseHead.astro';
import Footer from '../../../../components/Footer.astro';
import Header from '../../../../components/Header.astro';
import TodoForm from '../../../../components/TodoForm.astro';
import { localeFor, t } from '../../../../lib/i18n';
import { findTodoById } from '../../../../lib/todos';

// Middleware already guarantees a logged-in user here.
const lang = Astro.locals.lang;
const strings = t(lang);

const id = Number(Astro.params.id);
const todo = Number.isInteger(id) ? await findTodoById(id) : undefined;
if (!todo) return Astro.redirect('/admin/todos', 302);

// Present the stored todo back as editable JSON (drop internal fields).
const json = JSON.stringify(
	{
		title: todo.title,
		goal: todo.goal,
		timeEstimateHours: todo.timeEstimateHours,
		priority: todo.priority,
		ideas: todo.ideas,
		steps: todo.steps,
		notes: todo.notes,
		done: todo.done,
	},
	null,
	2,
);

const error = Astro.url.searchParams.get('error');
const errorMessage =
	error === 'json' ? strings.errInvalidJson : error === 'title' ? strings.errTodoTitle : null;
---

<!doctype html>
<html lang={localeFor(lang)}>
	<head>
		<BaseHead title={strings.editTodoHeading} description="Edit a todo." />
	</head>
	<body>
		<Header />
		<main>
			<div class="bar">
				<h1>{strings.editTodoHeading}</h1>
				<a class="back" href="/admin/todos">← {strings.todosHeading}</a>
			</div>
			{errorMessage && <p class="error">{errorMessage}</p>}
			<TodoForm action={`/api/todos/${todo.id}`} json={json} isEdit />
		</main>
		<Footer />
		<style>
			.bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}
			.back {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.9rem;
			}
			.back:hover {
				color: var(--accent);
			}
			.error {
				color: #b00020;
				font-weight: 700;
			}
		</style>
	</body>
</html>
