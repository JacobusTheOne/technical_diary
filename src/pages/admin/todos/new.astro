---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import TodoForm from '../../../components/TodoForm.astro';
import { strings } from '../../../lib/strings';
import { TODO_TEMPLATE_JSON } from '../../../lib/todos';

// Middleware already guarantees a logged-in user here.
const error = Astro.url.searchParams.get('error');
const errorMessage =
	error === 'json' ? strings.errInvalidJson : error === 'title' ? strings.errTodoTitle : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={strings.newTodoHeading} description="Add a new todo." />
	</head>
	<body>
		<Header />
		<main>
			<div class="bar">
				<h1>{strings.newTodoHeading}</h1>
				<a class="back" href="/admin/todos">← {strings.todosHeading}</a>
			</div>
			{errorMessage && <p class="error">{errorMessage}</p>}
			<TodoForm action="/api/todos" json={TODO_TEMPLATE_JSON} />
		</main>
		<Footer />
		<style>
			.bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}
			.back {
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.9rem;
			}
			.back:hover {
				color: var(--accent);
			}
			.error {
				color: #b00020;
				font-weight: 700;
			}
		</style>
	</body>
</html>
