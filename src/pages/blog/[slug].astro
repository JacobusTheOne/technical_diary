---
import { eq } from 'drizzle-orm';
import { marked } from 'marked';
import BlogPost from '../../layouts/BlogPost.astro';
import { getDb } from '../../lib/db';
import { posts as postsTable } from '../../lib/schema';

const { slug } = Astro.params;
const db = getDb();

const row =
	db && slug
		? (await db.select().from(postsTable).where(eq(postsTable.slug, slug)).limit(1))[0]
		: undefined;

if (!row) return new Response('Not found', { status: 404 });

// Body is Markdown authored by the (trusted) admin, rendered to HTML.
const html = await marked.parse(row.body);
---

<BlogPost title={row.title} pubDate={row.pubDate}>
	<Fragment set:html={html} />
</BlogPost>
