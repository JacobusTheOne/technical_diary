---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { localeFor, t } from '../../lib/i18n';
import { listPosts } from '../../lib/posts';

const posts = await listPosts();
const isAdmin = !!Astro.locals.user;
const lang = Astro.locals.lang;
const strings = t(lang);
---

<!doctype html>
<html lang={localeFor(lang)}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="bar">
				<h1>{strings.diaryHeading}</h1>
				<a class="new-btn" href={isAdmin ? '/admin/new' : '/login'}>{strings.newEntry}</a>
			</div>

			{posts.length === 0 && <p class="notice">{strings.noEntries}</p>}

			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.slug}`}>
								<span class="title">{post.title}</span>
								<FormattedDate date={post.pubDate} />
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
		<style>
			main {
				width: 720px;
			}
			.bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}
			.new-btn {
				flex: none;
				padding: 0.5rem 1rem;
				font-size: 0.95rem;
				font-weight: 700;
				color: white;
				background: var(--accent);
				border-radius: 8px;
				text-decoration: none;
			}
			.new-btn:hover {
				background: var(--accent-dark);
			}
			.notice {
				color: rgb(var(--gray));
			}
			ul {
				list-style: none;
				margin: 1.5rem 0 0 0;
				padding: 0;
			}
			li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			li a {
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
				padding: 1rem 0;
				text-decoration: none;
				color: rgb(var(--black));
			}
			li a:hover .title {
				color: var(--accent);
			}
			.title {
				font-size: 1.4rem;
				font-weight: 700;
				line-height: 1.2;
			}
			li a :global(time) {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
		</style>
	</body>
</html>
