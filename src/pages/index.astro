---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { localeFor } from '../lib/i18n';

const lang = Astro.locals.lang;
---

<!doctype html>
<html lang={localeFor(lang)}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			{
				lang === 'pt' ? (
					<>
						<h1>Diário Técnico</h1>
						<p>
							Um registro do que trabalho no dia a dia — as coisas que construo, os
							problemas que encontro e tudo o que aprendo pelo caminho. Na maior parte,
							anotações para o meu eu do futuro, compartilhadas abertamente.
						</p>
						<p>
							Vá até o <a href="/blog">diário</a> para ler as entradas mais recentes, ou
							veja a página <a href="/about">sobre</a> para entender o que é isto.
						</p>
					</>
				) : (
					<>
						<h1>Technical Diary</h1>
						<p>
							A running log of what I work on day to day — the things I build, the
							problems I run into, and whatever I learn along the way. Mostly notes to
							my future self, shared in the open.
						</p>
						<p>
							Head over to the <a href="/blog">diary</a> to read the latest entries, or
							check the <a href="/about">about</a> page to see what this is.
						</p>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>
